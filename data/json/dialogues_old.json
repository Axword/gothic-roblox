  "records": [
    {
      "id": "dlg_old_01",
      "npcId": "npc_old_01",
      "nodes": [
        {
          "id": "start",
          "text": "Nie przyszedłeś tu po prawdę. Prawda nie ma tu łóżka.",
          "responses": [
            {
              "text": "Szukam prawa do głosu.",
              "next": "task",
              "action": "startQuest:quest_main_arrival"
            },
            {
              "text": "Masz robotę dla nikogo?",
              "next": "oldwork"
            },
            {
              "text": "Odchodzę.",
              "action": "close"
            }
          ]
        },
        {
          "id": "work",
          "text": "Pytania są darmowe. Odpowiedzi zwykle nie.",
          "responses": [
            {
              "text": "Rozumiem.",
              "action": "close"
            }
          ]
        },
        {
          "id": "task",
          "text": "Prawo ma cenę. Najpierw udowodnij, że nie jesteś tylko kolejnym problemem.",
          "responses": [
            {
              "text": "Wezmę robotę.",
              "action": "startQuest:quest_old_01"
            },
            {
              "text": "Nie dziś.",
              "action": "close"
            }
          ]
        },
        {
          "id": "oldwork",
          "text": "Porządek sam się nie policzy. Brud też nie.",
          "responses": [
            {
              "text": "Biorę Twardą bramę.",
              "action": "startQuest:quest_old_01"
            },
            {
              "text": "Raport: brama załatwiona.",
              "action": "completeQuest:quest_old_01"
            },
            {
              "text": "Biorę Rejestr długów.",
              "action": "startQuest:quest_old_02"
            },
            {
              "text": "Raport: rejestr odzyskany.",
              "action": "completeQuest:quest_old_02"
            },
            {
              "text": "Przysięgam Kordonowi.",
              "action": "chooseFaction:kordon"
            },
            {
              "text": "Dość.",
              "action": "close"
            }
          ]
        }
      ]
    },
